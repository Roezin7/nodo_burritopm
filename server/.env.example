# Conexión a Postgres (Coolify). Usa una base de datos PROPIA, separada de cualquier otro proyecto.
DATABASE_URL="postgresql://usuario:password@host:5432/dbname?sslmode=require"

# Secreto para firmar JWT (cámbialo por un valor largo y aleatorio, propio de este proyecto)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Puerto del servidor (el proxy inyecta PORT automáticamente)
PORT=3000

# API de Anthropic — para el borrador de conteo IA (fase posterior). Opcional.
ANTHROPIC_API_KEY=""

# Entorno
NODE_ENV="development"

# CORS: orígenes permitidos separados por coma. Vacío = solo mismo origen (lo normal
# en el despliegue de un solo servicio). Ej: "https://abasto.burritoparrilla.com"
ALLOWED_ORIGINS=""
