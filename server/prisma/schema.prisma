generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
//  NÚCLEO MULTI-ORGANIZACIÓN + AUTH (Bloque 0)
//  Burrito Parrilla Mexicana: una organización (negocio) con muchas ubicaciones
//  (bodega central + sucursales). El dominio de inventario se construye en los
//  bloques siguientes.
// ===========================================================================

enum RolUsuario {
  admin // administrador general
  encargado_bodega // rol unificado: bodega + reparto
  encargado_sucursal
}

// Las dos operaciones comparten clientes y facturación, pero tienen inventarios,
// calendarios, rutas y documentos independientes.
enum LineaOperacion {
  carne
  desechables
}

enum TipoEmpresaCliente {
  interna
  externa
}

enum TipoProductoOperacion {
  desechable
  materia_prima
  proteina
  precio_fijo
  servicio
}

enum EstadoPedidoOperativo {
  borrador
  confirmado
  en_preparacion
  despachado
  entregado
  cerrado
  cancelado
}

enum EstadoCompra {
  pendiente
  pagada
  cancelada
}

enum EstadoSemana {
  abierta
  cerrada
  reabierta
}

enum EstadoFactura {
  borrador
  emitida
  pagada
  anulada
}

model negocios {
  id                  BigInt    @id @default(autoincrement())
  nombre              String
  tipo                String?
  zona_horaria        String    @default("America/Chicago")
  // Operación: si está activo, la carga exige una verificación de 1 toque antes de salir a ruta.
  verificacion_carga  Boolean   @default(false)
  // Reparto es opcional: apagado, Despacho pasa directo a la validación de Recepción.
  reparto_habilitado  Boolean   @default(false)
  // Días de la semana (0=Dom … 6=Sáb) en que se habilita el inventario para todas las ubicaciones.
  inventario_dias     Int[]     @default([])
  // Fecha en que se envió el aviso push "hoy toca inventario" (evita duplicados al reiniciar).
  aviso_inventario_at DateTime? @db.Date
  // Horas tras la carga después de las cuales el tránsito sin confirmar se cierra solo (0 = desactivado).
  auto_cierre_horas   Int       @default(0)
  // Fecha del último aviso al admin de sucursales rezagadas en inventario (idempotencia del scheduler).
  aviso_rezagados_at  DateTime? @db.Date
  creado_at           DateTime  @default(now()) @db.Timestamptz(6)

  usuarios            usuarios[]
  ubicaciones         ubicaciones[]
  categorias          categorias[]
  unidades            unidades[]
  products            products[]
  empresas_clientes   empresas_clientes[]
  pedidos_operativos  pedidos_operativos[]
  plantillas_ruta     plantillas_ruta[]
  proveedores         proveedores[]
  compras             compras[]
  producciones        producciones[]
  semanas_operativas  semanas_operativas[]
  inventario_semanal  inventario_semanal[]
  auditoria_operativa auditoria_operativa[]
  facturas            facturas[]
  recetas_produccion  recetas_produccion[]
}

model usuarios {
  id                  BigInt     @id @default(autoincrement())
  negocio_id          BigInt
  nombre              String
  rol                 RolUsuario @default(encargado_sucursal)
  pin_hash            String
  activo              Boolean    @default(true)
  // Se incrementa al cambiar PIN, rol o estado para revocar sesiones anteriores.
  auth_version        Int        @default(1)
  requiere_cambio_pin Boolean    @default(false)
  creado_at           DateTime   @default(now()) @db.Timestamptz(6)
  negocios            negocios   @relation(fields: [negocio_id], references: [id])

  ubicaciones_asignadas usuario_ubicaciones[]

  @@index([negocio_id])
}

// ===========================================================================
//  UBICACIONES — bodega central + sucursales (Bloque 1)
// ===========================================================================

enum TipoUbicacion {
  bodega
  sucursal
}

model ubicaciones {
  id                      BigInt             @id @default(autoincrement())
  negocio_id              BigInt
  nombre                  String
  codigo                  String
  direccion               String?
  tipo                    TipoUbicacion
  activo                  Boolean            @default(true)
  // Orden de captura/visualización heredado de los libros operativos.
  orden_operativo         Int                @default(999)
  creado_at               DateTime           @default(now()) @db.Timestamptz(6)
  empresa_cliente_id      BigInt?
  // Burlington se factura por separado, pero físicamente se entrega en Aurora.
  entrega_en_ubicacion_id BigInt?
  negocios                negocios           @relation(fields: [negocio_id], references: [id])
  empresa_cliente         empresas_clientes? @relation(fields: [empresa_cliente_id], references: [id])
  entrega_en              ubicaciones?       @relation("PuntoEntrega", fields: [entrega_en_ubicacion_id], references: [id])
  recibe_para             ubicaciones[]      @relation("PuntoEntrega")

  usuarios_asignados  usuario_ubicaciones[]
  producto_ubicacion  producto_ubicacion[]
  conteos             conteos[]
  distribucion_lineas distribucion_lineas[]
  historial_pedidos   historial_pedidos[]
  existencias         existencias[]
  ruta_paradas        ruta_paradas[]
  mov_origen          movimientos_inventario[] @relation("mov_origen")
  mov_destino         movimientos_inventario[] @relation("mov_destino")
  pedidos_operativos  pedidos_operativos[]
  plantilla_paradas   plantilla_ruta_paradas[]
  compras             compras[]
  producciones        producciones[]
  facturas            facturas[]
  lotes_materia_prima lotes_materia_prima[]
  inventario_semanal  inventario_semanal[]

  @@unique([negocio_id, codigo])
  @@index([negocio_id])
  @@index([negocio_id, orden_operativo])
  @@index([empresa_cliente_id])
}

// Relación editable entre la materia prima comprada y cada salida de producción.
// `sin_costo` identifica subproductos vendibles (p. ej. Carnitas) que no absorben
// el costo del batch principal.
model recetas_produccion {
  id                 BigInt  @id @default(autoincrement())
  negocio_id         BigInt
  materia_prima_id   BigInt
  producto_salida_id BigInt  @unique
  sin_costo          Boolean @default(false)
  orden              Int     @default(0)

  negocio         negocios @relation(fields: [negocio_id], references: [id])
  materia_prima   products @relation("receta_materia", fields: [materia_prima_id], references: [id], onDelete: Cascade)
  producto_salida products @relation("receta_salida", fields: [producto_salida_id], references: [id], onDelete: Cascade)

  @@unique([materia_prima_id, producto_salida_id])
  @@index([negocio_id, materia_prima_id])
}

// Razón comercial que paga las facturas. Una empresa puede tener varias ubicaciones;
// cada ubicación conserva su propia factura, como en los libros actuales.
model empresas_clientes {
  id                       BigInt             @id @default(autoincrement())
  negocio_id               BigInt
  nombre                   String
  codigo                   String
  tipo                     TipoEmpresaCliente
  dias_credito_carne       Int                @default(0)
  dias_credito_desechables Int                @default(0)
  activo                   Boolean            @default(true)
  creado_at                DateTime           @default(now()) @db.Timestamptz(6)

  negocios    negocios             @relation(fields: [negocio_id], references: [id])
  ubicaciones ubicaciones[]
  pedidos     pedidos_operativos[]
  facturas    facturas[]

  @@unique([negocio_id, codigo])
  @@unique([negocio_id, nombre])
  @@index([negocio_id])
}

// Asignación usuario ↔ ubicación (Bloque 2). El admin ve todo; bodega/sucursal se
// restringen a sus ubicaciones asignadas.
model usuario_ubicaciones {
  usuario_id   BigInt
  ubicacion_id BigInt
  usuarios     usuarios    @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  ubicaciones  ubicaciones @relation(fields: [ubicacion_id], references: [id], onDelete: Cascade)

  @@id([usuario_id, ubicacion_id])
  @@index([ubicacion_id])
}

// ===========================================================================
//  CATÁLOGO — categorías, unidades y productos con conversiones (Bloque 3)
//  Cantidades Decimal(12,3) (admiten fracciones); costos/factores Decimal(12,4).
// ===========================================================================

model categorias {
  id         BigInt     @id @default(autoincrement())
  negocio_id BigInt
  nombre     String
  orden      Int        @default(0)
  activo     Boolean    @default(true)
  negocios   negocios   @relation(fields: [negocio_id], references: [id])
  products   products[]

  @@unique([negocio_id, nombre])
  @@index([negocio_id])
}

model unidades {
  id         BigInt   @id @default(autoincrement())
  negocio_id BigInt
  nombre     String // Caja, Pieza, Galón, Bolsa, Rollo, Botella, Paquete…
  activo     Boolean  @default(true)
  negocios   negocios @relation(fields: [negocio_id], references: [id])

  productos_compra       products[] @relation("unidad_compra")
  productos_almacen      products[] @relation("unidad_almacen")
  productos_distribucion products[] @relation("unidad_distribucion")

  @@unique([negocio_id, nombre])
  @@index([negocio_id])
}

model products {
  id            BigInt  @id @default(autoincrement())
  negocio_id    BigInt
  nombre        String
  sku           String
  codigo_barras String?
  categoria_id  BigInt?

  // Unidades. La de distribución es la que cuenta/recibe la sucursal (requerida).
  // Compra y almacén (para reabasto de bodega, Fase 3) son opcionales por ahora.
  unidad_distribucion_id      BigInt
  unidad_compra_id            BigInt?
  unidad_almacen_id           BigInt?
  factor_compra_almacen       Decimal @default(1) @db.Decimal(12, 4)
  factor_almacen_distribucion Decimal @default(1) @db.Decimal(12, 4)

  // Costos (manuales en MVP; promedio ponderado en Fase 3).
  costo_promedio Decimal? @db.Decimal(12, 4)
  ultimo_costo   Decimal? @db.Decimal(12, 4)

  administrado_bodega    Boolean                @default(true)
  requiere_refrigeracion Boolean                @default(false)
  stock_min_bodega       Decimal?               @db.Decimal(12, 3)
  stock_seguridad_bodega Decimal?               @db.Decimal(12, 3)
  lead_time_dias         Int?
  imagen_url             String?
  activo                 Boolean                @default(true)
  // Mantiene el renglón exacto del producto en pedidos, inventarios y Excel.
  orden_operativo        Int                    @default(999)
  linea_operacion        LineaOperacion?
  tipo_operativo         TipoProductoOperacion?
  // Productos no producidos (tamal, chile relleno, adobo, carnitas, pulpa, etc.).
  precio_venta_fijo      Decimal?               @db.Decimal(12, 4)
  // Solo proteínas producidas: $15 por caja. Los demás productos quedan en cero.
  markup_caja            Decimal                @default(0) @db.Decimal(12, 4)
  // Terminado: peso estándar por caja. Materia prima: peso promedio ponderado por caja.
  peso_caja_lb           Decimal?               @db.Decimal(12, 3)
  // Días de producción sugeridos (0=Dom … 6=Sáb); el admin siempre puede producir fuera de programa.
  produccion_dias        Int[]                  @default([])

  negocios             negocios                  @relation(fields: [negocio_id], references: [id])
  categorias           categorias?               @relation(fields: [categoria_id], references: [id])
  unidad_distribucion  unidades                  @relation("unidad_distribucion", fields: [unidad_distribucion_id], references: [id])
  unidad_compra        unidades?                 @relation("unidad_compra", fields: [unidad_compra_id], references: [id])
  unidad_almacen       unidades?                 @relation("unidad_almacen", fields: [unidad_almacen_id], references: [id])
  producto_ubicacion   producto_ubicacion[]
  conteo_lineas        conteo_lineas[]
  distribucion_lineas  distribucion_lineas[]
  historial_pedidos    historial_pedidos[]
  existencias          existencias[]
  movimientos          movimientos_inventario[]
  pedido_lineas        pedido_operativo_lineas[]
  compra_lineas        compra_lineas[]
  produccion_materia   producciones[]            @relation("produccion_materia")
  produccion_salidas   produccion_salidas[]
  factura_lineas       factura_lineas[]
  lotes_materia_prima  lotes_materia_prima[]
  inventario_semanal   inventario_semanal[]
  recetas_como_materia recetas_produccion[]      @relation("receta_materia")
  recetas_como_salida  recetas_produccion[]      @relation("receta_salida")

  @@unique([negocio_id, sku])
  @@unique([negocio_id, nombre])
  @@index([negocio_id])
  @@index([negocio_id, orden_operativo])
}

// ===========================================================================
//  STOCK OBJETIVO por (producto, ubicación) — niveles par (Bloque 4)
// ===========================================================================

enum OrigenCalculo {
  manual
  historico
  automatico
}

model producto_ubicacion {
  id                    BigInt        @id @default(autoincrement())
  negocio_id            BigInt
  ubicacion_id          BigInt
  product_id            BigInt
  habilitado            Boolean       @default(true)
  stock_objetivo        Decimal       @default(0) @db.Decimal(12, 3)
  stock_min             Decimal       @default(0) @db.Decimal(12, 3)
  stock_max             Decimal?      @db.Decimal(12, 3)
  stock_seguridad       Decimal       @default(0) @db.Decimal(12, 3)
  frecuencia_abasto     String?
  consumo_promedio      Decimal?      @db.Decimal(12, 3)
  dias_cobertura        Int?
  multiplo_distribucion Decimal       @default(1) @db.Decimal(12, 3)
  minimo_envio          Decimal       @default(0) @db.Decimal(12, 3)
  origen_calculo        OrigenCalculo @default(manual)
  actualizado_at        DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  actualizado_por       BigInt?

  ubicaciones ubicaciones @relation(fields: [ubicacion_id], references: [id], onDelete: Cascade)
  products    products    @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([ubicacion_id, product_id])
  @@index([negocio_id])
  @@index([product_id])
}

// ===========================================================================
//  CONTEO FÍSICO por ubicación (Bloque 5)
//  Un conteo cerrado = fotografía verificable del inventario de esa ubicación.
// ===========================================================================

enum EstadoConteo {
  borrador
  en_captura
  cerrado
  reabierto
}

// Pedidos históricos (migrados de los PDFs anteriores al sistema). Señal de demanda para
// el cálculo de stock objetivo cuando todavía no hay suficientes conteos. Puramente analítico:
// NO toca el ledger ni las existencias.
model historial_pedidos {
  id           BigInt   @id @default(autoincrement())
  negocio_id   BigInt
  ubicacion_id BigInt
  product_id   BigInt
  fecha        DateTime @db.Date
  cantidad     Decimal  @db.Decimal(12, 3)
  origen       String?  @default("import") // 'import' | 'pdf' | 'manual'
  creado_at    DateTime @default(now()) @db.Timestamptz(6)

  ubicaciones ubicaciones @relation(fields: [ubicacion_id], references: [id], onDelete: Cascade)
  products    products    @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([negocio_id])
  @@index([ubicacion_id, product_id, fecha])
}

model conteos {
  id           BigInt                @id @default(autoincrement())
  negocio_id   BigInt
  ubicacion_id BigInt
  estado       EstadoConteo          @default(en_captura)
  // Día de inventario al que pertenece (sesión por fecha). Una sesión por ubicación por día.
  fecha        DateTime?             @db.Date
  creado_por   BigInt
  creado_at    DateTime              @default(now()) @db.Timestamptz(6)
  cerrado_por  BigInt?
  cerrado_at   DateTime?             @db.Timestamptz(6)
  notas        String?
  ubicaciones  ubicaciones           @relation(fields: [ubicacion_id], references: [id])
  lineas       conteo_lineas[]
  ajustes_lote conteo_ajustes_lote[]

  @@index([negocio_id, ubicacion_id])
  @@index([ubicacion_id, estado])
  @@index([ubicacion_id, fecha])
}

// Cuando un inventario físico de Carnicería encuentra menos materia prima que la
// registrada, conserva exactamente qué lotes, peso y costo se dieron de baja. Así
// el inventario puede eliminarse/revertirse sin perder la trazabilidad de compras.
model conteo_ajustes_lote {
  conteo_id BigInt
  lote_id   BigInt
  cajas     Decimal @db.Decimal(12, 3)
  peso_lb   Decimal @db.Decimal(12, 3)
  costo     Decimal @db.Decimal(12, 2)

  conteo conteos             @relation(fields: [conteo_id], references: [id], onDelete: Cascade)
  lote   lotes_materia_prima @relation(fields: [lote_id], references: [id])

  @@id([conteo_id, lote_id])
  @@index([lote_id])
}

model conteo_lineas {
  conteo_id  BigInt
  product_id BigInt
  qty        Decimal  @default(0) @db.Decimal(12, 3)
  unidad_id  BigInt
  factor     Decimal  @default(1) @db.Decimal(12, 4)
  contado    Boolean  @default(false)
  atipico    Boolean  @default(false)
  comentario String?
  conteos    conteos  @relation(fields: [conteo_id], references: [id], onDelete: Cascade)
  products   products @relation(fields: [product_id], references: [id])

  @@id([conteo_id, product_id])
  @@index([product_id])
}

// ===========================================================================
//  DISTRIBUCIÓN — pedido maestro consolidado (Bloque 6, MVP hasta "aprobada")
//  Las etapas posteriores (preparación/carga/entrega) son Fase 2.
// ===========================================================================

enum EstadoDistribucion {
  borrador
  esperando_conteos
  calculada
  en_revision
  aprobada
  en_preparacion
  preparada
  verificada
  en_carga
  cargada
  en_transito
  parcialmente_entregada
  entregada
  cerrada
  cerrada_con_incidencias
  cancelada
}

model distribuciones {
  id              BigInt                @id @default(autoincrement())
  negocio_id      BigInt
  nombre          String?
  estado          EstadoDistribucion    @default(calculada)
  creado_por      BigInt
  creado_at       DateTime              @default(now()) @db.Timestamptz(6)
  aprobado_por    BigInt?
  aprobado_at     DateTime?             @db.Timestamptz(6)
  // Fase 2 — operación de bodega y entrega
  preparado_por   BigInt?
  preparado_at    DateTime?             @db.Timestamptz(6)
  verificado_por  BigInt?
  verificado_at   DateTime?             @db.Timestamptz(6)
  cargado_por     BigInt?
  cargado_at      DateTime?             @db.Timestamptz(6)
  notas           String?
  linea_operacion LineaOperacion?
  fecha_entrega   DateTime?             @db.Date
  semana_id       BigInt?
  lineas          distribucion_lineas[]
  rutas           rutas[]
  semana          semanas_operativas?   @relation(fields: [semana_id], references: [id])

  @@index([negocio_id])
}

model distribucion_lineas {
  id                    BigInt   @id @default(autoincrement())
  distribucion_id       BigInt
  ubicacion_destino_id  BigInt
  product_id            BigInt
  conteo_id             BigInt?
  inventario_disponible Decimal  @default(0) @db.Decimal(12, 3)
  en_transito           Decimal  @default(0) @db.Decimal(12, 3)
  stock_objetivo        Decimal  @default(0) @db.Decimal(12, 3)
  stock_seguridad       Decimal  @default(0) @db.Decimal(12, 3)
  cantidad_sugerida     Decimal  @default(0) @db.Decimal(12, 3)
  cantidad_aprobada     Decimal? @db.Decimal(12, 3)
  // Fase 2 — cantidades por etapa
  cantidad_preparada    Decimal? @db.Decimal(12, 3)
  cantidad_verificada   Decimal? @db.Decimal(12, 3)
  cantidad_cargada      Decimal? @db.Decimal(12, 3)
  cantidad_recibida     Decimal? @db.Decimal(12, 3)
  estado_linea          String?
  incidencia_id         BigInt?
  costo_unitario        Decimal? @db.Decimal(12, 4)
  costo_total           Decimal? @db.Decimal(12, 2)
  pedido_linea_id       BigInt?

  distribuciones distribuciones           @relation(fields: [distribucion_id], references: [id], onDelete: Cascade)
  ubicaciones    ubicaciones              @relation(fields: [ubicacion_destino_id], references: [id])
  products       products                 @relation(fields: [product_id], references: [id])
  pedido_linea   pedido_operativo_lineas? @relation(fields: [pedido_linea_id], references: [id])

  @@index([distribucion_id])
  @@index([ubicacion_destino_id])
  @@index([product_id])
}

// ===========================================================================
//  LEDGER de inventario + existencias + incidencias (Bloque 8 / Fase 2)
//  Todo cambio de inventario es un movimiento; existencias es el saldo derivado.
// ===========================================================================

enum TipoMovInventario {
  conteo_inicial
  compra_recibida
  transferencia
  devolucion
  consumo
  merma
  dano
  ajuste_positivo
  ajuste_negativo
  cancelacion
  correccion
  recepcion_parcial
}

model existencias {
  negocio_id          BigInt
  ubicacion_id        BigInt
  product_id          BigInt
  cantidad_disponible Decimal  @default(0) @db.Decimal(12, 3)
  cantidad_reservada  Decimal  @default(0) @db.Decimal(12, 3)
  cantidad_transito   Decimal  @default(0) @db.Decimal(12, 3)
  costo_promedio      Decimal? @db.Decimal(12, 4)
  actualizado_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  ubicaciones ubicaciones @relation(fields: [ubicacion_id], references: [id], onDelete: Cascade)
  products    products    @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@id([ubicacion_id, product_id])
  @@index([negocio_id])
  @@index([product_id])
}

model movimientos_inventario {
  id                   BigInt            @id @default(autoincrement())
  negocio_id           BigInt
  product_id           BigInt
  ubicacion_origen_id  BigInt?
  ubicacion_destino_id BigInt?
  tipo                 TipoMovInventario
  cantidad             Decimal           @db.Decimal(12, 3)
  costo_unitario       Decimal?          @db.Decimal(12, 4)
  costo_total          Decimal?          @db.Decimal(12, 2)
  documento_tipo       String?
  documento_id         BigInt?
  usuario_id           BigInt
  fecha                DateTime          @default(now()) @db.Timestamptz(6)
  comentario           String?
  idempotency_key      String            @unique

  products          products     @relation(fields: [product_id], references: [id])
  ubicacion_origen  ubicaciones? @relation("mov_origen", fields: [ubicacion_origen_id], references: [id])
  ubicacion_destino ubicaciones? @relation("mov_destino", fields: [ubicacion_destino_id], references: [id])

  @@index([negocio_id])
  @@index([product_id])
  @@index([documento_tipo, documento_id])
}

model incidencias {
  id                    BigInt    @id @default(autoincrement())
  negocio_id            BigInt
  tipo                  String
  prioridad             String    @default("media")
  ubicacion_id          BigInt?
  documento_tipo        String?
  documento_id          BigInt?
  distribucion_linea_id BigInt?
  product_id            BigInt?
  responsable_id        BigInt?
  estado                String    @default("abierta")
  comentarios           String?
  creado_at             DateTime  @default(now()) @db.Timestamptz(6)
  resuelto_at           DateTime? @db.Timestamptz(6)
  resuelto_por          BigInt?

  @@index([negocio_id, estado])
}

// ===========================================================================
//  RUTAS DE ENTREGA (Bloque 12)
//  El admin planea una ruta: subconjunto ordenado de sucursales de una
//  distribución. El repartidor entrega parada por parada (1 toque) y la
//  sucursal confirma la recepción aparte. La ruta solo orquesta el orden y el
//  estado de entrega; el inventario lo sigue moviendo la recepción (recibir).
// ===========================================================================

enum EstadoRuta {
  planificada // el admin la está armando
  en_curso // el camión salió (distribución en tránsito)
  completada // todas las paradas entregadas
  cerrada
  cancelada
}

enum EstadoParada {
  pendiente // aún no llega el repartidor
  en_camino // siguiente parada activa
  entregada // el repartidor dejó la orden
  confirmada // la sucursal confirmó la recepción
  con_incidencia // entrega/recepción con diferencia
  omitida // no se entregó (se saltó la parada)
}

model rutas {
  id              BigInt           @id @default(autoincrement())
  negocio_id      BigInt
  distribucion_id BigInt
  nombre          String?
  estado          EstadoRuta       @default(planificada)
  repartidor_id   BigInt?
  creado_por      BigInt
  creado_at       DateTime         @default(now()) @db.Timestamptz(6)
  despachada_at   DateTime?        @db.Timestamptz(6)
  completada_at   DateTime?        @db.Timestamptz(6)
  notas           String?
  plantilla_id    BigInt?
  fecha_entrega   DateTime?        @db.Date
  distribuciones  distribuciones   @relation(fields: [distribucion_id], references: [id], onDelete: Cascade)
  plantilla       plantillas_ruta? @relation(fields: [plantilla_id], references: [id])
  paradas         ruta_paradas[]

  @@index([negocio_id])
  @@index([distribucion_id])
  @@index([repartidor_id])
}

// ===========================================================================
// PEDIDOS OPERATIVOS — separados por línea y fecha de entrega.
// El admin puede capturar por cualquier restaurante, aunque no tenga usuario.
// ===========================================================================

model pedidos_operativos {
  id                 BigInt                @id @default(autoincrement())
  negocio_id         BigInt
  empresa_cliente_id BigInt
  ubicacion_id       BigInt
  linea_operacion    LineaOperacion
  fecha_entrega      DateTime              @db.Date
  estado             EstadoPedidoOperativo @default(borrador)
  capturado_por      BigInt
  creado_at          DateTime              @default(now()) @db.Timestamptz(6)
  actualizado_at     DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  confirmado_at      DateTime?             @db.Timestamptz(6)
  notas              String?

  negocios  negocios                  @relation(fields: [negocio_id], references: [id])
  empresa   empresas_clientes         @relation(fields: [empresa_cliente_id], references: [id])
  ubicacion ubicaciones               @relation(fields: [ubicacion_id], references: [id])
  lineas    pedido_operativo_lineas[]

  @@unique([ubicacion_id, linea_operacion, fecha_entrega])
  @@index([negocio_id, fecha_entrega])
  @@index([empresa_cliente_id])
}

model pedido_operativo_lineas {
  id              BigInt   @id @default(autoincrement())
  pedido_id       BigInt
  product_id      BigInt
  cantidad        Decimal  @db.Decimal(12, 3)
  // Se congela al cerrar la semana; antes de eso refleja la regla vigente del producto.
  precio_unitario Decimal? @db.Decimal(12, 4)
  notas           String?

  pedido              pedidos_operativos    @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  producto            products              @relation(fields: [product_id], references: [id])
  distribucion_lineas distribucion_lineas[]

  @@unique([pedido_id, product_id])
  @@index([product_id])
}

// ===========================================================================
// PLANTILLAS DE RUTA — defaults editables y orden especial por fecha.
// ===========================================================================

model plantillas_ruta {
  id              BigInt         @id @default(autoincrement())
  negocio_id      BigInt
  nombre          String
  codigo          String
  linea_operacion LineaOperacion
  dia_semana      Int
  conductor       String
  activo          Boolean        @default(true)
  creado_at       DateTime       @default(now()) @db.Timestamptz(6)

  negocios negocios                 @relation(fields: [negocio_id], references: [id])
  paradas  plantilla_ruta_paradas[]
  rutas    rutas[]

  @@unique([negocio_id, codigo])
  @@index([negocio_id, linea_operacion, dia_semana])
}

model plantilla_ruta_paradas {
  plantilla_id BigInt
  ubicacion_id BigInt
  orden        Int
  opcional     Boolean @default(false)

  plantilla plantillas_ruta @relation(fields: [plantilla_id], references: [id], onDelete: Cascade)
  ubicacion ubicaciones     @relation(fields: [ubicacion_id], references: [id])

  @@id([plantilla_id, ubicacion_id])
  @@unique([plantilla_id, orden])
}

// ===========================================================================
// COMPRAS / PRODUCCIÓN — batches con peso, costo, yield y promedio ponderado.
// ===========================================================================

model proveedores {
  id         BigInt   @id @default(autoincrement())
  negocio_id BigInt
  nombre     String
  activo     Boolean  @default(true)
  creado_at  DateTime @default(now()) @db.Timestamptz(6)

  negocios negocios  @relation(fields: [negocio_id], references: [id])
  compras  compras[]

  @@unique([negocio_id, nombre])
  @@index([negocio_id])
}

model compras {
  id             BigInt       @id @default(autoincrement())
  negocio_id     BigInt
  proveedor_id   BigInt
  ubicacion_id   BigInt
  fecha          DateTime     @db.Date
  vence_at       DateTime     @db.Date
  referencia     String?
  total          Decimal      @db.Decimal(12, 2)
  estado         EstadoCompra @default(pendiente)
  registrado_por BigInt
  creado_at      DateTime     @default(now()) @db.Timestamptz(6)
  pagado_at      DateTime?    @db.Timestamptz(6)

  negocios  negocios        @relation(fields: [negocio_id], references: [id])
  proveedor proveedores     @relation(fields: [proveedor_id], references: [id])
  ubicacion ubicaciones     @relation(fields: [ubicacion_id], references: [id])
  lineas    compra_lineas[]

  @@index([negocio_id, fecha])
  @@index([proveedor_id, estado])
}

model compra_lineas {
  id            BigInt  @id @default(autoincrement())
  compra_id     BigInt
  product_id    BigInt
  cajas         Decimal @db.Decimal(12, 3)
  peso_total_lb Decimal @db.Decimal(12, 3)
  costo_total   Decimal @db.Decimal(12, 2)
  congelado     Boolean @default(false)

  compra   compras              @relation(fields: [compra_id], references: [id], onDelete: Cascade)
  producto products             @relation(fields: [product_id], references: [id])
  lote     lotes_materia_prima?

  @@index([product_id])
}

// Cada compra conserva su peso real. Producción consume lotes frescos por antigüedad;
// congelar/descongelar cambia disponibilidad operativa, nunca reescribe el costo.
model lotes_materia_prima {
  id                 BigInt   @id @default(autoincrement())
  negocio_id         BigInt
  ubicacion_id       BigInt
  product_id         BigInt
  compra_linea_id    BigInt?  @unique
  fecha              DateTime @db.Date
  congelado          Boolean  @default(false)
  cajas_iniciales    Decimal  @db.Decimal(12, 3)
  cajas_disponibles  Decimal  @db.Decimal(12, 3)
  peso_inicial_lb    Decimal  @db.Decimal(12, 3)
  peso_disponible_lb Decimal  @db.Decimal(12, 3)
  costo_inicial      Decimal  @db.Decimal(12, 2)
  costo_disponible   Decimal  @db.Decimal(12, 2)
  creado_at          DateTime @default(now()) @db.Timestamptz(6)

  ubicacion    ubicaciones                @relation(fields: [ubicacion_id], references: [id])
  producto     products                   @relation(fields: [product_id], references: [id])
  compra_linea compra_lineas?             @relation(fields: [compra_linea_id], references: [id], onDelete: SetNull)
  consumos     produccion_consumos_lote[]
  ajustes      conteo_ajustes_lote[]

  @@index([negocio_id, product_id, congelado])
  @@index([ubicacion_id, fecha])
}

model producciones {
  id                  BigInt   @id @default(autoincrement())
  negocio_id          BigInt
  ubicacion_id        BigInt
  materia_prima_id    BigInt
  fecha               DateTime @db.Date
  cajas_materia_prima Decimal  @db.Decimal(12, 3)
  peso_entrada_lb     Decimal  @db.Decimal(12, 3)
  costo_entrada       Decimal  @db.Decimal(12, 2)
  peso_salida_lb      Decimal  @db.Decimal(12, 3)
  desperdicio_lb      Decimal  @db.Decimal(12, 3)
  yield_porcentaje    Decimal  @db.Decimal(8, 4)
  registrado_por      BigInt
  creado_at           DateTime @default(now()) @db.Timestamptz(6)
  notas               String?

  negocios      negocios                   @relation(fields: [negocio_id], references: [id])
  ubicacion     ubicaciones                @relation(fields: [ubicacion_id], references: [id])
  materia_prima products                   @relation("produccion_materia", fields: [materia_prima_id], references: [id])
  salidas       produccion_salidas[]
  consumos      produccion_consumos_lote[]

  @@index([negocio_id, fecha])
  @@index([materia_prima_id])
}

model produccion_consumos_lote {
  produccion_id BigInt
  lote_id       BigInt
  cajas         Decimal @db.Decimal(12, 3)
  peso_lb       Decimal @db.Decimal(12, 3)
  costo         Decimal @db.Decimal(12, 2)

  produccion producciones        @relation(fields: [produccion_id], references: [id], onDelete: Cascade)
  lote       lotes_materia_prima @relation(fields: [lote_id], references: [id])

  @@id([produccion_id, lote_id])
  @@index([lote_id])
}

model produccion_salidas {
  id                BigInt  @id @default(autoincrement())
  produccion_id     BigInt
  product_id        BigInt
  cajas             Decimal @db.Decimal(12, 3)
  peso_caja_lb      Decimal @db.Decimal(12, 3)
  peso_total_lb     Decimal @db.Decimal(12, 3)
  costo_total       Decimal @db.Decimal(12, 2)
  costo_caja        Decimal @db.Decimal(12, 4)
  precio_venta_caja Decimal @db.Decimal(12, 4)

  produccion producciones @relation(fields: [produccion_id], references: [id], onDelete: Cascade)
  producto   products     @relation(fields: [product_id], references: [id])

  @@index([product_id])
}

// ===========================================================================
// CIERRE / FACTURACIÓN — semana actual + dos previas, AP y saldo de inventario.
// ===========================================================================

model semanas_operativas {
  id                 BigInt       @id @default(autoincrement())
  negocio_id         BigInt
  anio               Int
  semana             Int
  inicia_at          DateTime     @db.Date
  termina_at         DateTime     @db.Date
  estado             EstadoSemana @default(abierta)
  cerrado_por        BigInt?
  cerrado_at         DateTime?    @db.Timestamptz(6)
  valor_carne        Decimal      @default(0) @db.Decimal(14, 2)
  valor_congelado    Decimal      @default(0) @db.Decimal(14, 2)
  valor_desechables  Decimal      @default(0) @db.Decimal(14, 2)
  cuentas_por_cobrar Decimal      @default(0) @db.Decimal(14, 2)
  cuentas_por_pagar  Decimal      @default(0) @db.Decimal(14, 2)
  balance_neto       Decimal      @default(0) @db.Decimal(14, 2)

  negocios           negocios             @relation(fields: [negocio_id], references: [id])
  distribuciones     distribuciones[]
  facturas           facturas[]
  inventario_semanal inventario_semanal[]

  @@unique([negocio_id, anio, semana])
  @@index([negocio_id, termina_at])
}

// Fotografía contable del inventario al cerrar cada semana. Los libros históricos
// nunca deben depender del saldo vivo ni de costos editados después del cierre.
model inventario_semanal {
  semana_id           BigInt
  negocio_id          BigInt
  ubicacion_id        BigInt
  product_id          BigInt
  cantidad_disponible Decimal  @db.Decimal(12, 3)
  cantidad_reservada  Decimal  @db.Decimal(12, 3)
  cantidad_transito   Decimal  @db.Decimal(12, 3)
  costo_promedio      Decimal? @db.Decimal(12, 4)
  creado_at           DateTime @default(now()) @db.Timestamptz(6)

  semana    semanas_operativas @relation(fields: [semana_id], references: [id], onDelete: Cascade)
  negocio   negocios           @relation(fields: [negocio_id], references: [id])
  ubicacion ubicaciones        @relation(fields: [ubicacion_id], references: [id])
  producto  products           @relation(fields: [product_id], references: [id])

  @@id([semana_id, ubicacion_id, product_id])
  @@index([negocio_id, semana_id])
  @@index([product_id])
}

// Bitácora append-only de eliminaciones/correcciones materiales. No tiene relación
// al usuario para conservar el evento incluso si esa cuenta se elimina después.
model auditoria_operativa {
  id         BigInt   @id @default(autoincrement())
  negocio_id BigInt
  usuario_id BigInt
  accion     String
  entidad    String
  entidad_id BigInt?
  datos      Json
  creado_at  DateTime @default(now()) @db.Timestamptz(6)

  negocio negocios @relation(fields: [negocio_id], references: [id])

  @@index([negocio_id, creado_at])
  @@index([entidad, entidad_id])
}

model facturas {
  id                   BigInt         @id @default(autoincrement())
  negocio_id           BigInt
  semana_id            BigInt
  empresa_cliente_id   BigInt
  ubicacion_id         BigInt
  linea_operacion      LineaOperacion
  numero               String
  emitida_at           DateTime       @db.Date
  vence_at             DateTime       @db.Date
  estado               EstadoFactura  @default(borrador)
  subtotal             Decimal        @db.Decimal(12, 2)
  total                Decimal        @db.Decimal(12, 2)
  version              Int            @default(1)
  reemplaza_factura_id BigInt?
  creado_at            DateTime       @default(now()) @db.Timestamptz(6)

  negocios   negocios           @relation(fields: [negocio_id], references: [id])
  semana     semanas_operativas @relation(fields: [semana_id], references: [id])
  empresa    empresas_clientes  @relation(fields: [empresa_cliente_id], references: [id])
  ubicacion  ubicaciones        @relation(fields: [ubicacion_id], references: [id])
  reemplaza  facturas?          @relation("FacturaVersion", fields: [reemplaza_factura_id], references: [id])
  reemplazos facturas[]         @relation("FacturaVersion")
  lineas     factura_lineas[]
  pagos      pagos_cliente[]

  @@unique([negocio_id, numero, version])
  @@index([empresa_cliente_id, estado])
  @@index([semana_id])
}

// Marca cargas históricas que deben ejecutarse una sola vez en cada base de datos.
// Permite que Coolify reintente el arranque sin restablecer datos modificados después.
model importaciones_sistema {
  negocio_id  BigInt
  clave       String
  aplicado_at DateTime @default(now()) @db.Timestamptz(6)

  @@id([negocio_id, clave])
}

model factura_lineas {
  id              BigInt  @id @default(autoincrement())
  factura_id      BigInt
  product_id      BigInt?
  descripcion     String
  cantidad        Decimal @db.Decimal(12, 3)
  precio_unitario Decimal @db.Decimal(12, 4)
  importe         Decimal @db.Decimal(12, 2)

  factura  facturas  @relation(fields: [factura_id], references: [id], onDelete: Cascade)
  producto products? @relation(fields: [product_id], references: [id])

  @@index([factura_id])
}

model pagos_cliente {
  id             BigInt   @id @default(autoincrement())
  factura_id     BigInt
  monto          Decimal  @db.Decimal(12, 2)
  pagado_at      DateTime @db.Date
  registrado_por BigInt
  creado_at      DateTime @default(now()) @db.Timestamptz(6)

  factura facturas @relation(fields: [factura_id], references: [id], onDelete: Cascade)

  @@index([factura_id])
}

// Suscripciones de Web Push por dispositivo (PWA). Una por endpoint del navegador.
model push_subscriptions {
  id         BigInt   @id @default(autoincrement())
  negocio_id BigInt
  usuario_id BigInt
  endpoint   String   @unique
  p256dh     String
  auth       String
  creado_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([usuario_id])
}

model ruta_paradas {
  id            BigInt       @id @default(autoincrement())
  ruta_id       BigInt
  ubicacion_id  BigInt
  orden         Int
  estado        EstadoParada @default(pendiente)
  entregada_por BigInt?
  entregada_at  DateTime?    @db.Timestamptz(6)
  confirmada_at DateTime?    @db.Timestamptz(6)
  notas         String?
  rutas         rutas        @relation(fields: [ruta_id], references: [id], onDelete: Cascade)
  ubicaciones   ubicaciones  @relation(fields: [ubicacion_id], references: [id])

  @@unique([ruta_id, ubicacion_id])
  @@index([ruta_id])
}
